generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostType {
  DEFAULT
  EVENT
  SALE
  CULTURE
}

model Category {
  id   BigInt @id @default(autoincrement())
  name String
  post Post[]
}

enum Role {
  USER
  LEGISLATOR
  ADMIN
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  // Optional for WebAuthn support
  Authenticator Authenticator[]

  firstName String
  lastName  String?
  bio       String?
  password  String
  role      Role    @default(USER)
  cityId    Int
  city      City    @relation(fields: [cityId], references: [id])

  posts          Post[]
  likes          Like[]
  comments       Comment[]
  UserInterested UserInterested[]

  isDeactivated Boolean @default(false)
  isDeleted     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// Optional for WebAuthn support
model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Post {
  id             BigInt           @id @default(autoincrement())
  title          String
  text           String
  media          Json?
  userId         String
  user           User             @relation(fields: [userId], references: [id])
  cityId         Int
  city           City             @relation(fields: [cityId], references: [id])
  likes          Like[]
  comments       Comment[]
  type           PostType
  // EventPost specific fields
  startAt        DateTime?
  endAt          DateTime?
  localisation   String?
  userInterested UserInterested[]
  // SalePost specific fields
  categoryId     BigInt?
  category       Category?        @relation(fields: [categoryId], references: [id])
  price          Float?           @default(1)
  isDonation     Boolean?

  isVisible Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  id     BigInt @id @default(autoincrement())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  postId BigInt?
  post   Post?   @relation(fields: [postId], references: [id])
}

model UserInterested {
  userId String
  user   User   @relation(fields: [userId], references: [id])

  postId BigInt
  Post   Post   @relation(fields: [postId], references: [id])

  @@id([userId, postId])
}

model City {
  id Int @id @default(autoincrement())

  name    String
  zipCode String

  latitude  String
  longitude String

  users User[]
  posts Post[]
}

model Comment {
  id   BigInt @id @default(autoincrement())
  text String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  postId BigInt?
  post   Post?   @relation(fields: [postId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
